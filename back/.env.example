APP_NAME=MonClubHouse
APP_URL=https://monclubhouse.fr
NODE_ENV=production
PORT=3000

# Base de données
DB_HOST=localhost
DB_PORT=3306
DB_NAME=monclubhouse_db
DB_USER=monclubhouse_user
DB_PASS=votre_mot_de_passe_db

# JWT
JWT_SECRET=votre_secret_jwt_tres_long_et_aleatoire
JWT_REFRESH_SECRET=votre_secret_refresh_jwt_different
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth 2.0
GOOGLE_CLIENT_ID=votre_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=votre_google_client_secret
GOOGLE_CALLBACK_URL=https://monclubhouse.fr/auth/google/callback

# API FFF (Football France)
FFF_API_KEY=votre_cle_api_fff
FFF_API_URL=https://api.fff.fr/v1

# Socket.io
SOCKET_CORS_ORIGIN=https://monclubhouse.fr

# Upload fichiers
UPLOAD_PATH=./public/uploads
MAX_FILE_SIZE=5242880

# ─── Email / SMTP Hostinger ────────────────────────────────────────────────
# Port 587 = STARTTLS (recommandé), Port 465 = SSL (SMTP_SECURE=true)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=convocations@monclubhouse.fr
SMTP_PASS=votre_mot_de_passe_email_hostinger
