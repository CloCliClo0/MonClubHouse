{
  "name": "monclubhouse",
  "version": "1.0.0",
  "description": "MonClubHouse - Gestion de club sportif (workspace root)",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix back && npm install --prefix front",
    "install:back": "npm install --prefix back",
    "install:front": "npm install --prefix front",
    "start": "npm start --prefix back",
    "dev": "npm run dev --prefix back",
    "build": "npm run build --prefix front",
    "migrate": "npm run migrate --prefix back",
    "migrate:undo": "npm run migrate:undo --prefix back"
  }
}
