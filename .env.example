# ── Application ──────────────────────────────────────────
APP_NAME=MonClubHouse
APP_URL=https://monclubhouse.fr
NODE_ENV=production
PORT=3000

# ── Base de données ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=monclubhouse_db
DB_USER=
DB_PASS=

# ── JWT ───────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Google OAuth 2.0 ──────────────────────────────────────
GOOGLE_CLIENT_ID=371543726267-adv1uct1ca2b2c6l47c5f4h3q0ic9e93.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://monclubhouse.fr/auth/google/callback

# ── API FFF ───────────────────────────────────────────────
FFF_API_KEY=
FFF_API_URL=https://api.fff.fr

# ── Socket.io ─────────────────────────────────────────────
SOCKET_CORS_ORIGIN=https://monclubhouse.fr

# ── Uploads ───────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=5
